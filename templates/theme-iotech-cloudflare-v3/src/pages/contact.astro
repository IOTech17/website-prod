---
import Base from "../layouts/Base.astro";
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "contact");
if (page && Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base title={page?.data.title ?? "Contact"} description="Contactez IØTech pour vos besoins informatiques en Charente-Maritime.">
	<section class="page-hero contact-hero-centered">
		<div class="page-hero-inner">
			<p class="page-eyebrow">IØTECH</p>
			<h1 class="page-title">{page?.data.title ?? "Contact"}</h1>
			<p class="page-subtitle-hero">Un projet, une panne ou une question ? Réponse rapide pour les PME et indépendants.</p>
		</div>
	</section>

	<div class="contact-outer">
		<div class="contact-form-card">
			<div id="form-success" class="form-success-banner" hidden>
				<p>✓ Message envoyé. Nous vous répondrons dans les plus brefs délais.</p>
			</div>
			<form id="contact-form">
				<div class="contact-name-row">
					<div class="form-group">
						<input type="text" id="firstname" name="firstname" class="form-input" placeholder="Prénom" />
					</div>
					<div class="form-group">
						<input type="text" id="name" name="name" class="form-input" placeholder="Nom" required />
					</div>
				</div>
				<div class="form-group">
					<input type="email" id="email" name="email" class="form-input" placeholder="Email" required />
				</div>
				<div class="form-group">
					<input type="tel" id="phone" name="phone" class="form-input" placeholder="Téléphone" />
				</div>
				<div class="form-group">
					<textarea id="message" name="message" class="form-input" style="min-height:150px;resize:vertical" placeholder="Message" required></textarea>
				</div>
				<div id="form-error" class="form-error-msg" hidden></div>
				<button type="submit" id="form-submit" class="form-submit">Envoyer</button>
			</form>

			<div class="contact-info-block">
				{page?.data.body ? (
					<PortableText value={page.data.body} />
				) : (
					<>
						<p><strong>Adresse :</strong> Saint-Pierre-d'Oléron, Charente-Maritime</p>
						<p><strong>Téléphone :</strong> <a href="tel:+33600000000">+33 6 00 00 00 00</a></p>
						<p><strong>Courriel :</strong> <a href="mailto:contact@iotech17.com">contact@iotech17.com</a></p>
					</>
				)}
			</div>
		</div>
	</div>
</Base>

<style>
.contact-outer {
	background: var(--bg-1);
	padding: 4rem 1.5rem 6rem;
}
.contact-form-card {
	background: var(--bg-2);
	border: 1px solid var(--border);
	border-radius: 8px;
	padding: 2.5rem 2rem;
	width: 100%;
	max-width: 540px;
	margin: 0 auto;
	box-shadow: var(--panel-shadow);
}
.contact-name-row {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 1rem;
}
.form-group { margin-bottom: 1.25rem; }
.form-input {
	width: 100%;
	padding: 0.75rem 1rem;
	border: 1px solid var(--border-bright);
	border-radius: 4px;
	font-size: 1rem;
	color: var(--text-0);
	background: var(--bg-0);
	transition: border-color 0.12s, box-shadow 0.12s;
	box-sizing: border-box;
	font-family: inherit;
}
.form-input::placeholder { color: var(--text-2); }
.form-input:focus {
	outline: none;
	border-color: var(--accent);
	box-shadow: 0 0 0 3px var(--accent-glow);
}
.form-submit {
	padding: 0.75rem 2rem;
	background: var(--accent);
	color: #fff;
	border: none;
	border-radius: 4px;
	font-size: 1rem;
	font-weight: 600;
	cursor: pointer;
	transition: background 0.12s;
	font-family: inherit;
}
.form-submit:hover { background: var(--accent-dim); }
.contact-info-block {
	margin-top: 2rem;
	padding-top: 1.5rem;
	border-top: 1px solid var(--border);
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
	font-size: 0.9rem;
	color: var(--text-1);
}
.contact-info-block :global(p) { margin: 0; }
.contact-info-block :global(a) { color: var(--accent); text-decoration: none; }
.contact-info-block :global(a:hover) { text-decoration: underline; }
:global(.contact-hero-centered) { text-align: center; }
:global(.contact-hero-centered) .page-subtitle-hero { margin: 0 auto; }
.form-success-banner {
	background: color-mix(in srgb, var(--accent) 12%, transparent);
	border: 1px solid var(--accent);
	border-radius: 4px;
	padding: 1rem 1.25rem;
	margin-bottom: 1.5rem;
	color: var(--text-0);
	font-size: 0.95rem;
}
.form-success-banner p { margin: 0; }
.form-error-msg {
	color: #e05252;
	font-size: 0.9rem;
	margin-bottom: 0.75rem;
}
.form-submit:disabled { opacity: 0.65; cursor: not-allowed; }
@media (max-width: 480px) {
	.contact-name-row { grid-template-columns: 1fr; }
}
</style>

<script>
const form    = document.getElementById("contact-form") as HTMLFormElement | null;
const success = document.getElementById("form-success") as HTMLElement | null;
const errBox  = document.getElementById("form-error")   as HTMLElement | null;
const btn     = document.getElementById("form-submit")  as HTMLButtonElement | null;

form?.addEventListener("submit", async (e) => {
	e.preventDefault();
	if (!btn || !errBox || !success) return;

	btn.disabled    = true;
	btn.textContent = "Envoi en cours…";
	errBox.hidden   = true;

	try {
		const res  = await fetch("/api/contact", { method: "POST", body: new FormData(form!) });
		const data = await res.json() as { success?: boolean; error?: string };

		if (res.ok && data.success) {
			form!.hidden    = true;
			success.hidden  = false;
		} else {
			errBox.textContent = data.error ?? "Erreur lors de l'envoi. Veuillez réessayer.";
			errBox.hidden      = false;
			btn.disabled       = false;
			btn.textContent    = "Envoyer";
		}
	} catch {
		errBox.textContent = "Erreur réseau. Veuillez réessayer.";
		errBox.hidden      = false;
		btn.disabled       = false;
		btn.textContent    = "Envoyer";
	}
});
</script>
