---
import Base from "../layouts/Base.astro";
import { getEmDashCollection } from "emdash";

const { entries: services, cacheHint } = await getEmDashCollection("services");
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const svgIcons: Record<string, string> = {
	"creation-site": `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
	"sauvegarde": `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
	"cybersecurite": `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
	"depannage": `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
	"reseau": `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="6" height="6" rx="1"/><rect x="16" y="2" width="6" height="6" rx="1"/><rect x="9" y="16" width="6" height="6" rx="1"/><path d="M5 8v4h14V8"/><path d="M12 12v4"/></svg>`,
};
const fallbackIcon = `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`;

const priceMap: Record<string, string> = {
	"creation-site": "A partir de 890 EUR",
	"sauvegarde": "A partir de 49 EUR / mois",
	"cybersecurite": "Sur devis",
	"depannage": "A partir de 79 EUR",
	"reseau": "Sur devis",
};
---

<Base title="Services" description="Découvrez tous nos services informatiques pour PME en Charente-Maritime.">
	<header class="services-header page-hero">
		<div class="services-header-inner page-hero-inner">
			<p class="eyebrow page-eyebrow">IØTech</p>
			<h1 class="services-title page-title">Nos services</h1>
			<p class="services-subtitle page-subtitle">Une offre complète pour les PME et indépendants de Charente-Maritime</p>
		</div>
	</header>

	<div class="services-content page-shell">
		<section class="services-grid">
			{services.map(service => (
				<article class="service-card surface-card">
					<div class="service-icon" set:html={svgIcons[service.id] || fallbackIcon} />
					<h2 class="service-name">{service.data.title}</h2>
					{service.data.excerpt && (
						<p class="service-desc">{service.data.excerpt}</p>
					)}
					{priceMap[service.id] && (
						<p class="service-price">{priceMap[service.id]}</p>
					)}
				</article>
			))}
		</section>
	</div>
</Base>
