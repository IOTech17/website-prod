.wiki-save-bar { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.75rem; flex-wrap: wrap; }
.wiki-editor-status { font-size: 0.75rem; color: var(--text-2); }
.wiki-toolbar { display: flex; align-items: center; gap: 0.25rem; padding: 0.5rem 0.75rem; background: var(--bg-2); border: 1px solid var(--border); border-bottom: none; border-radius: 4px 4px 0 0; flex-wrap: wrap; }
.wiki-toolbar button { padding: 0.2rem 0.5rem; background: transparent; border: 1px solid transparent; border-radius: 3px; cursor: pointer; font-size: 0.78rem; color: var(--text-1); font-family: var(--font-mono); line-height: 1.4; }
.wiki-toolbar button:hover { background: var(--bg-3); border-color: var(--border); color: var(--text-0); }
.wiki-vis-select { background: var(--bg-1); border: 1px solid var(--border); border-radius: 3px; padding: 0.2rem 0.4rem; font-size: 0.72rem; color: var(--text-1); cursor: pointer; }
.wiki-ta { width: 100%; min-height: 420px; background: var(--bg-1); border: 1px solid var(--border); border-radius: 0 0 4px 4px; padding: 1.25rem; font-family: var(--font-mono); font-size: 0.85rem; line-height: 1.75; color: var(--text-0); resize: vertical; outline: none; tab-size: 2; }
.wiki-ta:focus { border-color: var(--accent); }
.wiki-editor-hint { font-size: 0.67rem; color: var(--text-2); margin-top: 0.4rem; }
.wiki-toc-title { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-2); margin-bottom: 0.6rem; }
.wiki-toc-link { display: block; color: var(--text-2); padding: 0.2rem 0.5rem; font-size: 0.75rem; text-decoration: none; border-left: 2px solid transparent; transition: all 0.1s; line-height: 1.4; }
.wiki-toc-link:hover { color: var(--accent); border-left-color: var(--accent); }
.wiki-toc-sub { padding-left: 1.25rem; font-size: 0.7rem; }

/* ── Dialog Déplacer ────────────────────────────────────────────────────── */
.wiki-dialog { border: 1px solid var(--border); border-radius: 8px; background: var(--bg-1); color: var(--text-0); padding: 0; min-width: min(460px, 92vw); max-width: 92vw; box-shadow: 0 24px 64px rgba(0,0,0,0.2); }
