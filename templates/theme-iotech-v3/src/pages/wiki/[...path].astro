---
import WikiLayout from "../../layouts/WikiLayout.astro";
import { buildTree, countNotes, getSiblings } from "../../utils/wiki-tree.ts";
import type { NoteEntry } from "../../utils/wiki-tree.ts";

const WIKI_SLUG = "wiki";
const _user = (Astro.locals as any).user;
const isAdmin = !!(_user && _user.role >= 50);

let wikiApiKey = import.meta.env.WIKI_API_KEY || "";
if (!wikiApiKey) {
	try {
		// @ts-ignore — cloudflare:workers is unavailable in Node.js dev mode
		const { env: cfEnv } = await import(/* @vite-ignore */ "cloudflare:workers");
		wikiApiKey = cfEnv?.WIKI_API_KEY || "";
	} catch { /* not on Cloudflare Workers */ }
}
const authHeaders: Record<string, string> = isAdmin && wikiApiKey
	? { "X-Wiki-Key": wikiApiKey }
	: {};

const emdash = (Astro.locals as any).emdash;

const pathParam = Astro.params.path;
const notePath = Array.isArray(pathParam) ? pathParam.join("/") : (pathParam || "");
// Astro already percent-decodes path params; re-decoding would throw on bare % chars.
let decodedPath: string;
try { decodedPath = decodeURIComponent(notePath); } catch { decodedPath = notePath; }
if (!decodedPath || decodedPath.startsWith("/") || decodedPath.split("/").some(s => s === ".." || s === "." || s === ""))
	return Astro.redirect("/404");

let allNotes: NoteEntry[] = [];
try {
	if (emdash?.handlePluginApiRoute) {
		// Direct dispatch — avoids self-referential HTTP fetch (unreliable on Cloudflare Workers)
		const req = new Request(new URL("/_emdash/api/plugins/markdown-wiki/notes", Astro.url), { headers: authHeaders });
		const result = await emdash.handlePluginApiRoute("markdown-wiki", "GET", "/notes", req);
		if (result?.success) allNotes = result.data?.notes || [];
	} else {
		const res = await fetch(new URL("/_emdash/api/plugins/markdown-wiki/notes", Astro.url).toString(), { headers: authHeaders });
		if (res.ok) {
			const data = await res.json();
			allNotes = data?.data?.notes || data?.notes || [];
		}
	}
} catch {}

const tree = buildTree(allNotes);
const total = countNotes(tree);
const siblings = getSiblings(allNotes, decodedPath);

let note: any = null;

try {
	if (emdash?.handlePluginApiRoute) {
		// Direct dispatch — avoids self-referential HTTP fetch (unreliable on Cloudflare Workers)
		const req = new Request(
			new URL("/_emdash/api/plugins/markdown-wiki/notes/get", Astro.url),
			{
				method: "POST",
				headers: { "Content-Type": "application/json", ...authHeaders },
				body: JSON.stringify({ path: decodedPath }),
			}
		);
		const noteResult = await emdash.handlePluginApiRoute("markdown-wiki", "POST", "/notes/get", req);
		if (!noteResult?.success) return Astro.redirect("/404");
		note = noteResult.data?.note || null;
		if (!note) return Astro.redirect("/404");
	} else {
		const noteRes = await fetch(
			new URL("/_emdash/api/plugins/markdown-wiki/notes/get", Astro.url).toString(),
			{
				method: "POST",
				headers: { "Content-Type": "application/json", ...authHeaders },
				body: JSON.stringify({ path: decodedPath }),
			}
		);
		if (!noteRes.ok) return Astro.redirect("/404");
		const noteData = await noteRes.json();
		note = noteData?.data?.note || noteData?.note || null;
		if (!note) return Astro.redirect("/404");
	}
} catch {
	return Astro.redirect("/404");
}

const RE_MD_EXT     = /\.md$/;
const RE_CODE_BLOCK = /```(\w*)\r?\n([\s\S]*?)```/g;
const RE_XML_AMP    = /&/g;
const RE_XML_LT     = /</g;
const RE_XML_GT     = />/g;
const RE_INLINE_CODE = /`([^`\n]+)`/g;
const RE_H6         = /^###### (.+)$/gm;
const RE_H5         = /^##### (.+)$/gm;
const RE_H4         = /^#### (.+)$/gm;
const RE_H3         = /^### (.+)$/gm;
const RE_H2         = /^## (.+)$/gm;
const RE_H1_MD      = /^# (.+)$/gm;
const RE_SLUG_WS    = /\s+/g;
const RE_SLUG_CHARS = /[^a-z0-9-]/g;
const RE_HR         = /^(-{3,}|\*{3,})$/gm;
const RE_BLOCKQUOTE = /^&gt; (.+)$/gm; // matches post-HTML-escape form
const RE_TABLE      = /(\|.+\|\n\|[-| :]+\|\n(?:\|.+\|\n?)+)/g;
const RE_UL         = /((?:^[ \t]*[-*+] .+\n?)+)/gm;
const RE_UL_PREFIX  = /^[ \t]*[-*+] /;
const RE_OL         = /((?:^\d+\. .+\n?)+)/gm;
const RE_OL_PREFIX  = /^\d+\. /;
const RE_BOLD_ITALIC = /\*\*\*(.+?)\*\*\*/g;
const RE_BOLD       = /\*\*(.+?)\*\*/g;
const RE_BOLD_U     = /(?<![a-zA-Z0-9_])__(.+?)__(?![a-zA-Z0-9_])/g;
const RE_ITALIC     = /\*(.+?)\*/g;
const RE_ITALIC_U   = /(?<![a-zA-Z0-9_])_(.+?)_(?![a-zA-Z0-9_])/g;
const RE_STRIKE     = /~~(.+?)~~/g;
const RE_WIKI_EMBED = /!\[\[([^\]|]+)(?:\|([^\]]+))?\]\]/g;
const RE_URL_SCHEME = /^[a-zA-Z][a-zA-Z0-9+.-]*:/;
const RE_IMAGE      = /!\[([^\]]*)\]\(([^)]+)\)/g;
const RE_LINK       = /\[([^\]]+)\]\(([^)]+)\)/g;
const IMAGE_EXTS    = /\.(png|jpe?g|gif|webp|svg|avif|bmp|tiff)$/i;
const RE_PARAGRAPH  = /^(?!<[a-z]|%%)(.*\S.*)$/gm;
const RE_XML_QUOT   = /"/g;
const RE_SAFE_HREF  = /^(https?:|mailto:|\/|#|\.\/)/i;
const RE_SAFE_SRC   = /^(https?:|\/|\.\/)/i;
const RE_ENT_AMP    = /&amp;/g;
const RE_ENT_LT     = /&lt;/g;
const RE_ENT_GT     = /&gt;/g;
const RE_ENT_QUOT   = /&quot;/g;
// Strips nonce placeholders (%%...%%) from heading text before slug generation
const RE_PLACEHOLDER = /%%[^%]+%%/g;

const esc = (s: string) =>
	s.replace(RE_XML_AMP, "&amp;").replace(RE_XML_LT, "&lt;").replace(RE_XML_GT, "&gt;").replace(RE_XML_QUOT, "&quot;");

const pathParts = decodedPath.split("/");
const breadcrumbs = pathParts.map((part, i) => ({
	name: i === pathParts.length - 1 ? part.replace(RE_MD_EXT, "") : part,
	isLast: i === pathParts.length - 1,
}));

function fmtDate(iso: string | null | undefined): string {
	if (!iso) return "—";
	const d = new Date(iso);
	if (isNaN(d.getTime())) return "—";
	return d.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
}

// Markdown → HTML (server-side, Web APIs only)
function mdToHtml(md: string): string {
	if (!md) return "";
	// Per-call nonce prevents user-authored %%CODE0%% literals from colliding with placeholders.
	const N = Math.random().toString(36).slice(2);
	const codeBlocks: string[] = [];
	let out = md.replace(RE_CODE_BLOCK, (_, lang, code) => {
		const safe = code.replace(RE_XML_AMP, "&amp;").replace(RE_XML_LT, "&lt;").replace(RE_XML_GT, "&gt;");
		codeBlocks.push(`<pre class="md-pre"><code class="language-${esc(lang || "text")}">${safe}</code></pre>`);
		return `%%CODE_${N}_${codeBlocks.length - 1}%%`;
	});
	const inlines: string[] = [];
	out = out.replace(RE_INLINE_CODE, (_, c) => {
		const safe = c.replace(RE_XML_AMP, "&amp;").replace(RE_XML_LT, "&lt;").replace(RE_XML_GT, "&gt;");
		inlines.push(`<code class="md-code">${safe}</code>`);
		return `%%INLINE_${N}_${inlines.length - 1}%%`;
	});
	// Convert Obsidian wiki embeds ![[file.ext]] / ![[file.ext|alias]] before
	// the generic image pass. Images render as <img>; other files as download links.
	out = out.replace(RE_WIKI_EMBED, (_, target: string, alias?: string) => {
		const t = target.trim();
		// Normalize relative paths to ./ so RE_SAFE_SRC and RE_SAFE_HREF accept them
		const href = (t.startsWith("/") || RE_URL_SCHEME.test(t)) ? t : `./${t}`;
		const display = alias?.trim() || t.split("/").pop() || t;
		if (IMAGE_EXTS.test(t)) {
			return `![${display}](${href})`;
		}
		return `[${display}](${href})`;
	});
	// Extract images and links before HTML-escaping so we can escape their content
	// individually while preserving the Markdown structure of the rest of the doc.
	const images: string[] = [];
	out = out.replace(RE_IMAGE, (_, alt, src) => {
		const s = src.trim();
		if (!RE_SAFE_SRC.test(s)) return esc(alt);
		images.push(`<img src="${esc(s)}" alt="${esc(alt)}" class="md-img">`);
		return `%%IMG_${N}_${images.length - 1}%%`;
	});
	const links: string[] = [];
	out = out.replace(RE_LINK, (_, text, href) => {
		const h = href.trim();
		if (!RE_SAFE_HREF.test(h)) return esc(text);
		links.push(`<a href="${esc(h)}" class="md-link">${esc(text)}</a>`);
		return `%%LINK_${N}_${links.length - 1}%%`;
	});
	// HTML-escape remaining Markdown source so headings, list items, table cells,
	// blockquotes, and paragraphs cannot inject raw HTML.
	out = out.replace(RE_XML_AMP, "&amp;").replace(RE_XML_LT, "&lt;").replace(RE_XML_GT, "&gt;");
	out = out.replace(RE_H6, (_, t) => `<h6>${t}</h6>`);
	out = out.replace(RE_H5, (_, t) => `<h5>${t}</h5>`);
	out = out.replace(RE_H4, (_, t) => `<h4>${t}</h4>`);
	out = out.replace(RE_H3, (_, t) => {
		const raw = t.replace(RE_PLACEHOLDER, "").replace(RE_ENT_AMP, "&").replace(RE_ENT_LT, "<").replace(RE_ENT_GT, ">").replace(RE_ENT_QUOT, '"').trim();
		const id = raw.toLowerCase().replace(RE_SLUG_WS, "-").replace(RE_SLUG_CHARS, "");
		return `<h3 id="${id}">${t}</h3>`;
	});
	out = out.replace(RE_H2, (_, t) => {
		const raw = t.replace(RE_PLACEHOLDER, "").replace(RE_ENT_AMP, "&").replace(RE_ENT_LT, "<").replace(RE_ENT_GT, ">").replace(RE_ENT_QUOT, '"').trim();
		const id = raw.toLowerCase().replace(RE_SLUG_WS, "-").replace(RE_SLUG_CHARS, "");
		return `<h2 id="${id}">${t}</h2>`;
	});
	out = out.replace(RE_H1_MD, (_, t) => `<h1>${t}</h1>`);
	out = out.replace(RE_HR, "<hr>");
	out = out.replace(RE_BLOCKQUOTE, (_, t) => `<blockquote>${t}</blockquote>`);
	out = out.replace(RE_TABLE, table => {
		const rows = table.trim().split("\n");
		// Slice off the leading and trailing empty strings from splitting "| a | b |"
		const ths = rows[0].split("|").slice(1, -1);
		const trs = rows.slice(2).map(r =>
			"<tr>" + r.split("|").slice(1, -1).map(c => `<td>${c.trim()}</td>`).join("") + "</tr>"
		).join("");
		return `<table><thead><tr>${ths.map(h => `<th>${h.trim()}</th>`).join("")}</tr></thead><tbody>${trs}</tbody></table>`;
	});
	out = out.replace(RE_UL, list => {
		// Join with \n so bold/italic regexes (which don't cross newlines) can't span items
		const items = list.trim().split("\n").map(l => `<li>${l.replace(RE_UL_PREFIX, "")}</li>`).join("\n");
		return `<ul>${items}</ul>`;
	});
	out = out.replace(RE_OL, list => {
		const items = list.trim().split("\n").map(l => `<li>${l.replace(RE_OL_PREFIX, "")}</li>`).join("\n");
		return `<ol>${items}</ol>`;
	});
	// Paragraph pass runs before inline formatting so lines starting with
	// <strong>/<em>/<del> (produced by bold/italic/strike) get a <p> wrapper.
	out = out.replace(RE_PARAGRAPH, "<p>$1</p>");
	out = out.replace(RE_BOLD_ITALIC, "<strong><em>$1</em></strong>");
	out = out.replace(RE_BOLD_U, "<strong>$1</strong>");
	out = out.replace(RE_BOLD, "<strong>$1</strong>");
	out = out.replace(RE_ITALIC_U, "<em>$1</em>");
	out = out.replace(RE_ITALIC, "<em>$1</em>");
	out = out.replace(RE_STRIKE, "<del>$1</del>");
	// Use function replacements to avoid $& / $` / $' / $$ interpolation in replacement strings
	codeBlocks.forEach((b, i) => { out = out.replace(`%%CODE_${N}_${i}%%`, () => b); });
	inlines.forEach((b, i) => { out = out.replace(`%%INLINE_${N}_${i}%%`, () => b); });
	links.forEach((b, i) => { out = out.replace(`%%LINK_${N}_${i}%%`, () => b); });
	images.forEach((b, i) => { out = out.replace(`%%IMG_${N}_${i}%%`, () => b); });
	return out;
}

const html = mdToHtml(note?.content || "");

const tocItems: Array<{ level: number; text: string; id: string }> = [];
const contentForToc = (note?.content || "").replace(/```(\w*)\r?\n[\s\S]*?```/g, "");
const hRe = /^#{2,3} (.+)$/gm;
let m;
while ((m = hRe.exec(contentForToc)) !== null) {
	const level = m[0].startsWith("###") ? 3 : 2;
	const text = m[1]!;
	// Strip inline code, images, and links to match the id produced by mdToHtml.
	const cleanText = text.replace(/`[^`]*`/g, "").replace(/!\[[^\]]*\]\([^)]*\)/g, "").replace(/\[([^\]]*)\]\([^)]*\)/g, "$1").trim();
	const id = cleanText.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "");
	tocItems.push({ level, text, id });
}
---

<WikiLayout
	title={note?.title || decodedPath}
	tree={tree}
	currentPath={decodedPath}
	totalNotes={total}
	wikiSlug={WIKI_SLUG}
	isAdmin={isAdmin}
>
	<div class="wiki-note-wrap">
		<nav class="wiki-bc" aria-label="Fil d'Ariane">
			<a href={`/${WIKI_SLUG}`}>Wiki</a>
			{breadcrumbs.map(crumb => (
				<>
					<span aria-hidden="true">/</span>
					<span class={crumb.isLast ? "wiki-bc-current" : ""}>{crumb.name}</span>
				</>
			))}
		</nav>

		<div class="wiki-note-grid">
			<article>
				<header class="wiki-note-header">
					<div class="wiki-note-title-row">
						<h1>{note?.title}</h1>
						{isAdmin && (
							<button id="wiki-edit-btn" class="btn btn-ghost wiki-edit-btn-sm">✏️ Modifier</button>
						)}
					</div>
					<div class="wiki-note-meta">
						<span>Modifié le {fmtDate(note?.updatedAt)}</span>
						{note?.tags?.length > 0 && (
							<div style="display:flex;gap:0.3rem;flex-wrap:wrap">
								{note.tags.map((t: string) => (
									<span class="wiki-tag">#{t}</span>
								))}
							</div>
						)}
					</div>
					<div class="wiki-note-path">{decodedPath}</div>
					{isAdmin && (
						<div id="wiki-save-bar" class="wiki-save-bar" hidden>
							<button class="wiki-save-btn btn btn-primary" style="font-size:0.8rem">💾 Sauvegarder</button>
							<button class="wiki-cancel-btn btn btn-ghost" style="font-size:0.8rem">✕ Annuler</button>
							<span id="wiki-editor-status" class="wiki-editor-status" hidden></span>
						</div>
					)}
				</header>

				<div id="wiki-view" class="wiki-body" set:html={html} />

				{isAdmin && (
					<div id="wiki-editor-wrap" hidden>
						<div class="wiki-toolbar" role="toolbar" aria-label="Formatage Markdown">
							<button data-cmd="bold" title="Gras (Ctrl+B)"><strong>B</strong></button>
							<button data-cmd="italic" title="Italique (Ctrl+I)"><em>I</em></button>
							<button data-cmd="strike" title="Barré (~~texte~~)">S̶</button>
							<button data-cmd="code" title="Code inline">`x`</button>
							<button data-cmd="codeblock" title="Bloc de code">```</button>
							<button data-cmd="h2" title="Titre H2">H2</button>
							<button data-cmd="h3" title="Titre H3">H3</button>
							<button data-cmd="link" title="Lien [texte](url)">🔗</button>
							<div style="flex:1"></div>
							<label for="wiki-vis-select" style="font-size:0.68rem;color:var(--text-2)">Visibilité</label>
							<select id="wiki-vis-select" class="wiki-vis-select">
								<option value="public">🌐 Publique</option>
								<option value="private">🔒 Privée</option>
								<option value="clients">👥 Clients</option>
							</select>
						</div>
						<textarea id="wiki-ta" class="wiki-ta" spellcheck="true" autocorrect="off" autocapitalize="off" placeholder="Contenu Markdown…"></textarea>
						<div class="wiki-editor-hint">Ctrl+S sauvegarder · Échap annuler · Tab indenter (2 espaces) · Ctrl+B gras · Ctrl+I italique</div>
					</div>
				)}

				<footer style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid var(--border)">
					<div style="display:flex;gap:0.5rem;margin-bottom:1.5rem;flex-wrap:wrap;align-items:center">
						<a href={`/${WIKI_SLUG}`} class="btn btn-ghost">← Wiki</a>
						{isAdmin && (
							<>
								<button id="wiki-move-btn" class="btn btn-ghost" style="font-size:0.78rem">🔀 Déplacer</button>
								<button id="wiki-delete-btn" class="btn btn-ghost" style="font-size:0.78rem;color:#e53e3e">🗑️ Supprimer</button>
							</>
						)}
					</div>
					{siblings.length > 0 && (
						<div>
							<div style="font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-2);margin-bottom:0.5rem">
								Dans le même dossier
							</div>
							{siblings.slice(0, 5).map(s => (
								<a href={`/${WIKI_SLUG}/${s.path.split("/").map((seg: string) => encodeURIComponent(seg)).join("/")}`}
									style="display:block;font-size:0.78rem;color:var(--text-1);padding:0.25rem 0;text-decoration:none">
									{s.title}
								</a>
							))}
						</div>
					)}
				</footer>
			</article>

			{tocItems.length > 2 && (
				<aside class="wiki-toc">
					<div class="wiki-toc-title">Sur cette page</div>
					{tocItems.map(h => (
						<a href={`#${h.id}`} class={`wiki-toc-link${h.level === 3 ? " wiki-toc-sub" : ""}`}>
							{h.text}
						</a>
					))}
				</aside>
			)}
		</div>
	</div>

	{isAdmin && (
		<div id="wiki-init-data"
			data-content={note?.content ?? ""}
			data-visibility={note?.visibility ?? "public"}
			hidden
		/>
	)}

	{isAdmin && (
		<dialog id="wiki-move-dialog" class="wiki-dialog">
			<div class="wiki-dialog-header">
				<span class="wiki-dialog-title">🔀 Déplacer la note</span>
				<button id="wiki-move-close" class="wiki-dialog-close" aria-label="Fermer">✕</button>
			</div>
			<div class="wiki-dialog-body">
				<div class="wiki-dialog-section">
					<div class="wiki-dialog-label">Note actuelle</div>
					<code id="wiki-move-current" class="wiki-dialog-code">{decodedPath}</code>
				</div>
				<div class="wiki-dialog-section">
					<div class="wiki-dialog-label">Dossiers existants <span id="wiki-move-folders-hint" style="font-weight:400;text-transform:none;letter-spacing:0">(cliquer pour déplacer dedans)</span></div>
					<div id="wiki-move-folders" class="wiki-move-folders">
						<span style="font-size:0.75rem;color:var(--text-2)">Chargement…</span>
					</div>
				</div>
				<div class="wiki-dialog-section">
					<label for="wiki-move-input" class="wiki-dialog-label">Nouveau chemin complet</label>
					<input
						type="text"
						id="wiki-move-input"
						class="wiki-move-input"
						spellcheck="false"
						autocomplete="off"
						placeholder="Dossier/Nom-de-la-note.md"
					/>
					<div class="wiki-dialog-hint">Ex : Archive/Bienvenue.md — le dossier est créé automatiquement.</div>
					<div id="wiki-move-error" class="wiki-dialog-error" hidden></div>
				</div>
			</div>
			<div class="wiki-dialog-footer">
				<button id="wiki-move-confirm" class="btn btn-primary">Déplacer</button>
				<button id="wiki-move-cancel" class="btn btn-ghost">Annuler</button>
			</div>
		</dialog>
	)}
</WikiLayout>

<script define:vars={{ isAdmin, notePath: decodedPath, wikiSlug: WIKI_SLUG, wikiApiKey: isAdmin ? wikiApiKey : "" }}>
async function doDelete() {
	if (!confirm(`Supprimer définitivement "${notePath}" ?`)) return;
	try {
		const res = await fetch("/_emdash/api/plugins/markdown-wiki/notes/delete", {
			method: "POST",
			headers: { "Content-Type": "application/json", "X-EmDash-Request": "1", ...(wikiApiKey ? { "X-Wiki-Key": wikiApiKey } : {}) },
			body: JSON.stringify({ path: notePath }),
		});
		if (!res.ok) {
			const err = await res.json().catch(() => ({}));
			throw new Error(err?.error?.message || `Erreur ${res.status}`);
		}
		window.location.href = `/${wikiSlug}`;
	} catch (e) { alert("Erreur lors de la suppression : " + e.message); }
}

if (isAdmin) {
	// Read note content and visibility from a hidden data element instead of
	// define:vars — JSON.stringify does not escape script-closing sequences.
	const initDataEl   = document.getElementById("wiki-init-data");
	const initContent  = initDataEl?.dataset.content  ?? "";
	const initVisibility = initDataEl?.dataset.visibility ?? "public";

	const editBtn    = document.getElementById("wiki-edit-btn");
	const saveBar    = document.getElementById("wiki-save-bar");
	const saveBtns   = document.querySelectorAll(".wiki-save-btn");
	const cancelBtns = document.querySelectorAll(".wiki-cancel-btn");
	const statusEl   = document.getElementById("wiki-editor-status");
	const view       = document.getElementById("wiki-view");
	const editorWrap = document.getElementById("wiki-editor-wrap");
	const ta         = document.getElementById("wiki-ta");
	const visSelect  = document.getElementById("wiki-vis-select");
	const moveBtn    = document.getElementById("wiki-move-btn");
	const deleteBtn  = document.getElementById("wiki-delete-btn");

	function setStatus(msg, isError) {
		if (!statusEl) return;
		statusEl.textContent = msg;
		statusEl.style.color = isError ? "#e53e3e" : "var(--text-2)";
		statusEl.hidden = !msg;
	}

	function enterEdit() {
		ta.value = initContent;
		visSelect.value = initVisibility;
		view.hidden = true;
		editorWrap.hidden = false;
		saveBar.hidden = false;
		editBtn.hidden = true;
		ta.focus();
		ta.setSelectionRange(0, 0);
	}

	function exitEdit() {
		view.hidden = false;
		editorWrap.hidden = true;
		saveBar.hidden = true;
		editBtn.hidden = false;
		setStatus("", false);
	}

	const authH = wikiApiKey ? { "X-Wiki-Key": wikiApiKey } : {};

	async function save() {
		if (!ta.value.trim()) { setStatus("Le contenu ne peut pas être vide.", true); return; }
		const content = ta.value;
		saveBtns.forEach(b => { b.disabled = true; b.textContent = "Sauvegarde…"; });
		setStatus("", false);
		try {
			const res = await fetch("/_emdash/api/plugins/markdown-wiki/notes/update", {
				method: "POST",
				headers: { "Content-Type": "application/json", "X-EmDash-Request": "1", ...authH },
				body: JSON.stringify({ path: notePath, content, visibility: visSelect.value }),
			});
			if (!res.ok) {
				const err = await res.json().catch(() => ({}));
				throw new Error(err?.error?.message || `Erreur ${res.status}`);
			}
			window.location.reload();
		} catch (e) {
			setStatus(e.message, true);
			saveBtns.forEach(b => { b.disabled = false; b.textContent = "💾 Sauvegarder"; });
		}
	}

	// ── Dialog Déplacer ───────────────────────────────────────────────────
	const moveDialog  = document.getElementById("wiki-move-dialog");
	const moveFolders = document.getElementById("wiki-move-folders");
	const moveInput   = document.getElementById("wiki-move-input");
	const moveError   = document.getElementById("wiki-move-error");
	const moveConfirm = document.getElementById("wiki-move-confirm");
	const moveCancel  = document.getElementById("wiki-move-cancel");
	const moveClose   = document.getElementById("wiki-move-close");

	async function openMoveDialog() {
		moveInput.value = notePath;
		moveError.hidden = true;
		moveConfirm.disabled = false;
		moveConfirm.textContent = "Déplacer";
		moveDialog.showModal();
		moveInput.select();

		// Charger les dossiers existants
		moveFolders.innerHTML = '<span style="font-size:0.75rem;color:var(--text-2)">Chargement…</span>';
		try {
			const res = await fetch("/_emdash/api/plugins/markdown-wiki/notes", {
				headers: authH,
			});
			const data = await res.json();
			const notes = data?.data?.notes || data?.notes || [];

			// Extraire tous les dossiers uniques
			const folders = new Set();
			for (const note of notes) {
				const parts = note.path.split("/");
				for (let i = 1; i < parts.length; i++) {
					folders.add(parts.slice(0, i).join("/"));
				}
			}

			if (folders.size === 0) {
				moveFolders.innerHTML = '<span style="font-size:0.75rem;color:var(--text-2)">Aucun dossier — créez des notes avec des sous-chemins.</span>';
			} else {
				moveFolders.textContent = "";
				for (const f of [...folders].toSorted()) {
					const btn = document.createElement("button");
					btn.className = "wiki-folder-chip";
					btn.type = "button";
					btn.dataset.folder = f;
					btn.textContent = "📁 " + f;
					btn.addEventListener("click", () => {
						const filename = notePath.split("/").pop();
						moveInput.value = `${f}/${filename}`;
						moveInput.focus();
					});
					moveFolders.appendChild(btn);
				}
			}
		} catch {
			moveFolders.innerHTML = '<span style="font-size:0.75rem;color:#e53e3e">Erreur de chargement.</span>';
		}
	}

	async function confirmMove() {
		const newPath = moveInput.value.trim();
		if (!newPath) { moveDialog.close(); return; }
		if (newPath === notePath) {
			moveError.textContent = "Le chemin est identique au chemin actuel.";
			moveError.hidden = false;
			return;
		}
		if (!newPath.endsWith(".md")) {
			moveError.textContent = 'Le chemin doit se terminer par ".md".';
			moveError.hidden = false;
			return;
		}
		if (newPath.split("/").some(s => s === ".." || s === "." || s === "")) {
			moveError.textContent = 'Le chemin ne peut pas contenir ".", ".." ou des segments vides.';
			moveError.hidden = false;
			return;
		}
		if (newPath.startsWith("/")) {
			moveError.textContent = 'Le chemin ne peut pas commencer par "/".';
			moveError.hidden = false;
			return;
		}
		moveConfirm.disabled = true;
		moveConfirm.textContent = "Déplacement…";
		moveError.hidden = true;
		try {
			const res = await fetch("/_emdash/api/plugins/markdown-wiki/notes/move", {
				method: "POST",
				headers: { "Content-Type": "application/json", "X-EmDash-Request": "1", ...authH },
				body: JSON.stringify({ path: notePath, newPath }),
			});
			if (!res.ok) {
				const err = await res.json().catch(() => ({}));
				throw new Error(err?.error?.message || `Erreur ${res.status}`);
			}
			const encoded = newPath.split("/").map(s => encodeURIComponent(s)).join("/");
			window.location.href = `/${wikiSlug}/${encoded}`;
		} catch (e) {
			moveError.textContent = e.message;
			moveError.hidden = false;
			moveConfirm.disabled = false;
			moveConfirm.textContent = "Déplacer";
		}
	}

	moveConfirm?.addEventListener("click", confirmMove);
	moveCancel?.addEventListener("click", () => moveDialog.close());
	moveClose?.addEventListener("click", () => moveDialog.close());
	moveInput?.addEventListener("keydown", e => {
		if (e.key === "Enter") confirmMove();
		if (e.key === "Escape") moveDialog.close();
	});
	moveDialog?.addEventListener("click", e => {
		if (e.target === moveDialog) moveDialog.close();
	});

	function doMove() { openMoveDialog(); }

	// Toolbar
	function wrapSel(before, after) {
		const a = after ?? before;
		const s = ta.selectionStart, e = ta.selectionEnd;
		const sel = ta.value.slice(s, e) || "texte";
		ta.setRangeText(before + sel + a, s, e, "select");
		ta.focus();
	}
	function insertPrefix(prefix) {
		const s = ta.selectionStart;
		const lineStart = ta.value.lastIndexOf("\n", s - 1) + 1;
		ta.setRangeText(prefix, lineStart, lineStart, "end");
		ta.focus();
	}

	document.querySelectorAll("[data-cmd]").forEach(btn => {
		btn.addEventListener("click", e => {
			e.preventDefault();
			switch (btn.dataset.cmd) {
				case "bold":      wrapSel("**"); break;
				case "italic":    wrapSel("*"); break;
				case "strike":    wrapSel("~~"); break;
				case "code":      wrapSel("`"); break;
				case "codeblock": wrapSel("```\n", "\n```"); break;
				case "h2":        insertPrefix("## "); break;
				case "h3":        insertPrefix("### "); break;
				case "link":      wrapSel("[", "](url)"); break;
			}
		});
	});

	ta?.addEventListener("keydown", e => {
		if ((e.ctrlKey || e.metaKey) && e.key === "s") { e.preventDefault(); save(); }
		if ((e.ctrlKey || e.metaKey) && e.key === "b") { e.preventDefault(); wrapSel("**"); }
		if ((e.ctrlKey || e.metaKey) && e.key === "i") { e.preventDefault(); wrapSel("*"); }
		if (e.key === "Escape") exitEdit();
		if (e.key === "Tab") {
			e.preventDefault();
			const s = ta.selectionStart;
			ta.setRangeText("  ", s, s, "end");
		}
	});

	editBtn?.addEventListener("click", enterEdit);
	saveBtns.forEach(b => b.addEventListener("click", save));
	cancelBtns.forEach(b => b.addEventListener("click", exitEdit));
	moveBtn?.addEventListener("click", doMove);
	deleteBtn?.addEventListener("click", doDelete);

	// Auto-edit si ?edit=1 dans l'URL (après création d'une note)
	if (new URLSearchParams(window.location.search).get("edit") === "1") {
		enterEdit();
		history.replaceState(null, "", window.location.pathname);
	}
}
</script>

