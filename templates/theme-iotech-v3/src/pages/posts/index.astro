---
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getEmDashCollection } from "emdash";

const cursor = Astro.url.searchParams.get("cursor") ?? undefined;
const limit = 12;

const { entries: posts, nextCursor, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit,
	cursor,
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base title="Blog">
	<section class="page-hero">
		<div class="page-hero-inner">
			<p class="page-eyebrow">Blog</p>
			<h1 class="page-title">Actualités</h1>
			<p class="page-subtitle-hero">Actualités, conseils et bonnes pratiques informatiques pour PME et indépendants.</p>
		</div>
	</section>

	<div class="page-shell">
		{posts.length > 0 ? (
			<div class="posts-grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr))">
				{posts.map(post => <PostCard post={post} />)}
			</div>
		) : (
			<p class="text-muted" style="padding:3rem 0;text-align:center">
				Aucun article publié pour le moment.
			</p>
		)}

		{(cursor || nextCursor) && (
			<div class="flex gap-2 mt-8" style="justify-content:center">
				{cursor && <a href="/posts" class="btn btn-ghost">← Début</a>}
				{nextCursor && <a href={`/posts?cursor=${encodeURIComponent(nextCursor)}`} class="btn btn-ghost">Suivant →</a>}
			</div>
		)}
	</div>
</Base>
